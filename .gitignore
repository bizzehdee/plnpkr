## ---------------------------------------------------------------------------
## Planning Poker — .gitignore (.NET + Angular)
## ---------------------------------------------------------------------------

## --- Project-specific ignores ---
# SQLite database files (created at runtime; never commit data)
*.db
*.db-shm
*.db-wal
*.sqlite$
*.sqlite3$
planningpoker.db*

# Single-artifact publish output
/publish/
**/publish/

## --- .NET / MSBuild ---
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
build/
artifacts/
*.user
*.suo
*.userosscache
*.sln.docstates
project.lock.json
project.fragment.lock.json

# .NET test / coverage output
[Tt]est[Rr]esults/
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml
*.trx
.coverage/

# Visual Studio / Rider
.vs/
.idea/
*.csproj.user

## --- Angular / Node ---
# Dependencies
node_modules/
**/node_modules/

# Build output
/frontend/dist/
**/dist/
.angular/
**/.angular/

# Frontend test / coverage output
/frontend/coverage/
**/coverage/

# npm / yarn / pnpm logs & caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# Local environment files
.env
.env.*
!.env.example

## --- Editors / OS ---
*.swp
*~
.DS_Store
Thumbs.db
